# ── myExtBot — environment variables ──────────────────────────────────────────
#
# Copy this file to .env (git-ignored) and fill in your values.
# The Tauri Rust backend reads these at startup via std::env::var().
#
# ┌─ REQUIRED: pick ONE LLM provider and fill in its key ─────────────────────┐
# │  • OpenAI   → set OPENAI_API_KEY                                           │
# │  • Anthropic → set ANTHROPIC_API_KEY                                       │
# │  • Ollama   → no key needed (install ollama + `ollama pull llama3.2`)      │
# └────────────────────────────────────────────────────────────────────────────┘
#
# All other variables are OPTIONAL (the app works with their built-in defaults).
#
# Usage:
#   cp .env.example .env
#   # edit .env, then:
#   cd apps/desktop && npm run dev

# ── LLM provider ──────────────────────────────────────────────────────────────
# Supported: openai | anthropic | ollama
LLM_PROVIDER=openai

# OpenAI (https://platform.openai.com/api-keys)
# To use an OpenAI-compatible proxy (e.g. https://xiaoai.plus), set OPENAI_BASE_URL
# and choose a model supported by that proxy (e.g. gemini-3.1-pro-preview).
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# Example — xiaoai.plus proxy:
# OPENAI_BASE_URL=https://xiaoai.plus
# OPENAI_MODEL=gemini-3.1-pro-preview

# Anthropic (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Ollama (local, no key needed — set LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ── Agent identity ─────────────────────────────────────────────────────────────
# Stable UUID for this bot instance. Generated automatically on first run
# if left blank; override here to keep the same ID across reinstalls.
AGENT_ID=
AGENT_NAME=MyBot
AGENT_ROLE=pm
AGENT_TEAM_ID=team-default

# ── Firecrawl API ─────────────────────────────────────────────────────────────
# Web scraping and crawling for LLM-ready data extraction.
# Get your API key at: https://firecrawl.dev
FIRECRAWL_API_KEY=fc-...
# Optional: override default request timeout in milliseconds (default: 30000)
# FIRECRAWL_TIMEOUT_MS=30000

# ── Tracing / logging ─────────────────────────────────────────────────────────
# Rust tracing level: error | warn | info | debug | trace
RUST_LOG=info
