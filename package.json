{
  "name": "myextbot-workspace",
  "private": true,
  "workspaces": [
    "apps/desktop",
    "services/playwright-sidecar"
  ],
  "scripts": {
    "dev:sidecar": "npm --workspace=services/playwright-sidecar run dev",
    "build:sidecar": "npm --workspace=services/playwright-sidecar run build",
    "dev:desktop": "npm --workspace=apps/desktop run tauri:dev",
    "build:desktop": "npm --workspace=apps/desktop run tauri:build"
  }
}
